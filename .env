# Qt runtime
QT_QPA_PLATFORM=windows
QT_QPA_FONTDIR=C:/Windows/Fonts

# UI fonts and label rendering
UI_FONT_FAMILY=Segoe UI
UI_BASE_FONT_POINT_SIZE=10
UI_MIN_LABEL_PIXEL_SIZE=3
UI_MAX_LABEL_PIXEL_SIZE=11
UI_LABEL_PADDING=0.10

# Default task
DEFAULT_TASK_NAME=demo_extreme

# GA defaults
GA_DEFAULT_POPULATION_SIZE=260
GA_DEFAULT_GENERATIONS=600
GA_DEFAULT_STAGNATION_LIMIT=140
GA_DEFAULT_TOURNAMENT_SIZE=3
GA_DEFAULT_SEED=42
GA_DEFAULT_MAX_TIME_SECONDS=120
GA_DEFAULT_P_CROSSOVER=0.90
GA_DEFAULT_P_ORDER_MUTATION=0.35
GA_DEFAULT_P_ROTATION_MUTATION=0.15
GA_DEFAULT_RANDOM_RATIO=0.40
GA_DEFAULT_HISTORY_TOP_K=10
GA_DEFAULT_IMMIGRANT_FRAC=0.15
GA_DEFAULT_POPULATION_STUDY_ENABLED=0
GA_DEFAULT_POPULATION_STUDY_VALUES=140,220,320,420,560

# Exhaustive baseline
BASELINE_EXHAUSTIVE_ENABLED=0
BASELINE_EXHAUSTIVE_MAX_ITEMS=6
BASELINE_EXHAUSTIVE_MAX_TIME_SECONDS=60

# Playback
UI_DEFAULT_PLAY_INTERVAL_MS=500
